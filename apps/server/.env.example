DATABASE_URL="file:./prisma/dev.db"
PORT=4000
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
AI_PROVIDER="openaiApi"
CODEX_PROVIDER_ENABLED="false"
# Browser-based ChatGPT sign-in alternative:
# AI_PROVIDER="codexChatgpt"
# CODEX_PROVIDER_ENABLED="true"
# This uses the bundled @openai/codex app-server adapter on the backend.
# It is best suited to trusted/local rich-client usage, not a public multi-user SaaS deployment.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
LLM_MODEL="gpt-4.1-mini"
