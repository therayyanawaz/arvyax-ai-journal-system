{
  "name": "arvyax-ai-journal-system",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/server",
    "apps/client"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,client \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm --workspace @arvyax/server run dev",
    "dev:client": "npm --workspace @arvyax/client run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "npm --workspace @arvyax/server run build",
    "build:client": "npm --workspace @arvyax/client run build",
    "test": "npm --workspace @arvyax/server run test",
    "db:generate": "npm --workspace @arvyax/server run db:generate",
    "db:migrate": "npm --workspace @arvyax/server run db:migrate",
    "db:studio": "npm --workspace @arvyax/server run db:studio",
    "seed": "npm --workspace @arvyax/server run seed",
    "verify:endpoints": "npm --workspace @arvyax/server run verify:endpoints"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
